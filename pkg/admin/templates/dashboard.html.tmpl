{{define "dashboard_body"}}
<h2 style="margin-top:0;font-size:.95rem;color:#8b949e">sing-box live log</h2>

<p style="color:#8b949e;font-size:.8rem;margin-bottom:1rem">
  Tail of <code>journalctl -u sing-box</code>, refreshing every 5 seconds. Each connection line
  shows the source IP and which user's key was used, giving per-user visibility.
</p>

<pre id="log" style="height: 32rem; overflow-y: auto">{{.LogTail}}</pre>

<script>
  async function refresh() {
    try {
      const r = await fetch('/dashboard/log');
      if (!r.ok) return;
      const text = await r.text();
      const el = document.getElementById('log');
      el.textContent = text;
      el.scrollTop = el.scrollHeight;
    } catch (e) {}
  }
  setInterval(refresh, 5000);
</script>
{{end}}
