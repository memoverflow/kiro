{{define "layout"}}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Kiro Admin — {{.Title}}</title>
<style>
* { box-sizing: border-box; }
body { margin: 0; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; background: #0d1117; color: #c9d1d9; }
header { background: #161b22; padding: 1rem 2rem; border-bottom: 1px solid #30363d; display: flex; align-items: center; gap: 2rem; }
header h1 { margin: 0; font-size: 1rem; color: #58a6ff; }
header nav { display: flex; gap: 1.5rem; font-size: .85rem; }
header nav a { color: #8b949e; text-decoration: none; }
header nav a:hover, header nav a.active { color: #c9d1d9; }
main { padding: 2rem; max-width: 1200px; margin: 0 auto; }
table { width: 100%; border-collapse: collapse; font-size: .85rem; }
th { text-align: left; padding: .5rem .8rem; background: #161b22; color: #8b949e; font-weight: 500; border-bottom: 1px solid #30363d; }
td { padding: .5rem .8rem; border-bottom: 1px solid #21262d; vertical-align: middle; }
td code { color: #d2a8ff; font-size: .8rem; }
button, .btn { background: #21262d; color: #c9d1d9; border: 1px solid #30363d; padding: .4rem .8rem; border-radius: 4px; cursor: pointer; font: inherit; font-size: .8rem; text-decoration: none; }
button:hover, .btn:hover { background: #30363d; }
button.danger { background: #4d1414; border-color: #8b2929; }
button.primary { background: #1f4d1f; border-color: #2ea043; }
form.inline { display: inline-block; margin: 0; }
input[type=text], input[type=password] { background: #0d1117; color: #c9d1d9; border: 1px solid #30363d; padding: .4rem .6rem; border-radius: 4px; font: inherit; font-size: .85rem; }
.alert { padding: .75rem 1rem; border-radius: 4px; margin-bottom: 1rem; font-size: .85rem; }
.alert.err { background: #4d1414; border: 1px solid #8b2929; }
.alert.ok { background: #1f4d1f; border: 1px solid #2ea043; }
pre { background: #161b22; padding: 1rem; border-radius: 4px; overflow-x: auto; font-size: .8rem; color: #c9d1d9; border: 1px solid #30363d; }
.footer { padding: 1rem 2rem; color: #484f58; font-size: .75rem; border-top: 1px solid #30363d; }
</style>
</head>
<body>
<header>
  <h1>Kiro Admin</h1>
  <nav>
    <a href="/" {{if eq .Page "users"}}class="active"{{end}}>Users</a>
    <a href="/audit" {{if eq .Page "audit"}}class="active"{{end}}>Audit log</a>
    <a href="/dashboard" {{if eq .Page "dashboard"}}class="active"{{end}}>Dashboard</a>
    <a href="/rotate" {{if eq .Page "rotate"}}class="active"{{end}}>Rotate server key</a>
  </nav>
  <div style="margin-left:auto;color:#8b949e;font-size:.8rem">admin: {{.Actor}}</div>
</header>
<main>
{{if .Flash}}<div class="alert {{.FlashKind}}">{{.Flash}}</div>{{end}}
{{.Body}}
</main>
<div class="footer">kiro-admin · EC2 Shadowsocks multi-user console</div>
</body>
</html>{{end}}
